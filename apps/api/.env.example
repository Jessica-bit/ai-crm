# Banco de dados
# Deve refletir as credenciais definidas em docker/docker-compose.yml
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_crm?schema=public"

# Aplicação
PORT=3001
NODE_ENV=development

# JWT
# Gere segredos fortes em produção, ex: openssl rand -base64 48
JWT_ACCESS_SECRET="troque-este-segredo-de-access-token"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="troque-este-segredo-de-refresh-token"
JWT_REFRESH_EXPIRES_IN="7d"
